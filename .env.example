# Embeddings — default: free local BGE (no API key)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Runtime backend: auto | fastembed (ONNX, Railway) | sentence_transformers (PyTorch, local dev)
EMBEDDING_BACKEND=auto
# Set true to auto-pick bge-small vs bge-large from chunk sizes (see ingestion/embed.py)
EMBEDDING_AUTO_BGE=true
# Index build batch size (lower = less peak RAM on Railway)
INDEX_BATCH_SIZE=16
# Warm embedding model at API startup (false saves RAM on free tier)
PRELOAD_EMBEDDING_MODEL=false
# Serve ui/ from FastAPI (false when UI is on Vercel)
SERVE_UI=true
# Optional: force large model for long passages / big indexes
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# LLM — Groq chat (Phase 5+). Omit key to use template answers (tests/CI).
GROQ_API_KEY=
CHAT_MODEL=llama-3.3-70b-versatile

# Paid OpenAI embeddings only (optional — set provider=openai and a key)
OPENAI_API_KEY=
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# Retrieval (Phase 4+)
TOP_K=5
# OpenAI embeddings: use 0.7. Local BGE uses 0.60 (scheme filter) / 0.55 (global) in retriever.
SIMILARITY_THRESHOLD=0.7

# Compliance links — refusal responses only
AMFI_EDUCATION_URL=https://www.amfiindia.com/investor/knowledge-center-info
SEBI_INVESTOR_URL=https://investor.sebi.gov.in/

# Corpus metadata
CORPUS_VERSION=1
INGESTED_AT=

# Daily ingestion (Phase 7 run_daily.py) + scheduler cron (Phase 8)
# 10:00 AM IST daily — see scheduler/cron.example and scheduler/README.md
INGEST_CRON_SCHEDULE=0 10 * * *
INGEST_TIMEZONE=Asia/Kolkata

# Chroma persistence (Phase 2+)
VECTOR_STORE_PATH=vector_store

# Phase 7 — daily ingest lock + dev admin reindex
INGEST_LOCK_TTL_SECONDS=7200
# Set a secret to enable POST /api/admin/reindex with header X-Admin-Token
ADMIN_REINDEX_TOKEN=
# Set false in production to disable admin reindex entirely (AP-08)
ADMIN_REINDEX_ENABLED=true
MAX_INGEST_CHUNK_DROP_RATIO=0.5

# Phase 9 — production API hardening
APP_ENV=development
# Comma-separated allowed UI origins (production). Empty uses dev defaults in app/main.py
CORS_ORIGINS=
# Chat requests per minute per IP. 0 = disabled in dev; production defaults to 30
CHAT_RATE_LIMIT_PER_MINUTE=0
