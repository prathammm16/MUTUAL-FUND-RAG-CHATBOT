# Production template — set these in Railway / Vercel dashboards (never commit real secrets).

# --- Railway (backend) ---
APP_ENV=production
GROQ_API_KEY=
CHAT_MODEL=llama-3.3-70b-versatile

VECTOR_STORE_PATH=/app/vector_store
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_AUTO_BGE=true
# OPENAI_API_KEY=
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

TOP_K=5
SIMILARITY_THRESHOLD=0.7
CORPUS_VERSION=1

# Comma-separated Vercel origin(s)
CORS_ORIGINS=https://your-app.vercel.app
CHAT_RATE_LIMIT_PER_MINUTE=30

ADMIN_REINDEX_ENABLED=false
ADMIN_REINDEX_TOKEN=

INGEST_CRON_SCHEDULE=0 10 * * *
INGEST_TIMEZONE=Asia/Kolkata
INGEST_LOCK_TTL_SECONDS=7200
MAX_INGEST_CHUNK_DROP_RATIO=0.5

AMFI_EDUCATION_URL=https://www.amfiindia.com/investor/knowledge-center-info
SEBI_INVESTOR_URL=https://investor.sebi.gov.in/

# --- Vercel (frontend build) ---
# VITE_API_BASE_URL=https://your-app.up.railway.app
